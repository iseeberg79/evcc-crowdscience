{
  "name": "@solar-htw/evcc-crowdscience",
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "cd apps/web && bun run dev",
    "format:check": "bun --bun prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "bun --bun prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "bun --bun eslint .",
    "lint:fix": "bun --bun eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@tanstack/eslint-plugin-router": "^1.141.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "latest",
    "eslint": "^9.39.2",
    "eslint-plugin-better-tailwindcss": "^4.0.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.52.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@orpc/contract": "^1.13.4"
  }
}
